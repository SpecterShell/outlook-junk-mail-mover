# Required: app registration (client) ID from Microsoft Entra / Azure.
# You can also generate this file interactively via:
#   uv run outlook_junk_mover.py --configure
OUTLOOK_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Use "common" for most cases. For personal Outlook.com/Hotmail/Live accounts,
# "consumers" is also a good option. For work/school only, use "organizations"
# or your specific tenant ID.
OUTLOOK_TENANT_ID=common

# Optional. Do not include reserved scopes like offline_access/openid/profile here;
# MSAL manages those itself.
# OUTLOOK_SCOPES=Mail.ReadWrite

# Exact email addresses are safer than entire domains.
OUTLOOK_ALLOWED_SENDERS=john.doe@example.com,noreply@example.com

# Optional: allow full domains too.
# OUTLOOK_ALLOWED_DOMAINS=example.com,contoso.com

# Optional: match by subject/body keyword too.
# OUTLOOK_SUBJECT_KEYWORDS=verification code,login code,one-time code
# OUTLOOK_BODY_KEYWORDS=verification code,login code,one-time code

# Set this to true only if you really want to move every message in Junk.
OUTLOOK_MOVE_ALL=false

# Poll every 5 minutes.
OUTLOOK_POLL_SECONDS=300

# Only consider junk messages from the last 7 days.
OUTLOOK_LOOKBACK_HOURS=168

# Scan up to this many recent junk messages per poll.
OUTLOOK_SCAN_LIMIT=50

# Uncomment to test without moving anything.
# OUTLOOK_DRY_RUN=true

# Token cache path.
OUTLOOK_TOKEN_CACHE_FILE=.tokens/msal_cache.json

# DEBUG, INFO, WARNING, ERROR, CRITICAL
OUTLOOK_LOG_LEVEL=INFO
